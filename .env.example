# GW1 Builds - Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL (set to your domain in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase - Get keys from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

# Supabase Access Token (for CLI) - https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_access_token

# GW1 Tactics demo URL (used by the announcement modal)
NEXT_PUBLIC_TACTICS_URL=https://tactics.gw1builds.com

# Discord invite link (permanent invite)
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/PgavhbaDMh

# Tactics preview-gate password (server-only, used by /api/tactics redirect)
TACTICS_SITE_PASSWORD=
